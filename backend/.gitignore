# ============================================================
# RecruitAI — Backend .gitignore (Express/Node.js API)
# Package Manager: npm (backend uses npm independently)
# ============================================================

# ─── Dependencies ────────────────────────────────────────────
node_modules/

# ─── Environment Files ───────────────────────────────────────
# Keep: .env.example (safe template)
# Ignore: all real secret files
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
.env*.local
!.env.example

# ─── Uploaded Resume Files ───────────────────────────────────
# User-uploaded files must NEVER be committed (privacy + size)
uploads/resumes/*.pdf
uploads/resumes/*.docx
uploads/resumes/*.doc
uploads/resumes/*.txt
uploads/resumes/*.png
uploads/resumes/*.jpg
# Keep the placeholder so the empty directory is tracked
!uploads/resumes/.gitkeep
!uploads/.gitignore

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Build / Cache ───────────────────────────────────────────
dist/
build/
.cache/
coverage/
*.tsbuildinfo

# ─── OS Files ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Security / Certs ────────────────────────────────────────
*.pem
*.key
*.cert
*.p12
*.pfx

# ─── Test scripts (PowerShell test scripts) ──────────────────
TEST_APIS.ps1
